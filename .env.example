# Copie para .env e preencha os valores (cp .env.example .env).
# O .env sobrepõe configs/config.yaml (precedência: init > env > .env > YAML).

# Credenciais DagsHub / MLflow (obrigatórias para `make train` / `make evaluate`).
DAGSHUB_TOKEN=your-dagshub-token-here
DAGSHUB_USER=your-dagshub-username
DAGSHUB_REPO_OWNER=JosueJNLui
DAGSHUB_REPO_NAME=fiap-mlet-challenge-fase-2

# Overrides opcionais (o YAML é a base; estes vencem).
# Chaves aninhadas usam o delimitador `__`. Descomente para um smoke run rápido:
# SEED=42
# DATA__N_USERS_SAMPLE=200
# EVAL__RANKING_N_USERS=50
